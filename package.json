{
  "name": "vegourmet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/fetch-ratings-snapshot.mjs && node scripts/fetch-reviews-snapshot.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "ratings:snapshot": "node scripts/fetch-ratings-snapshot.mjs",
    "reviews:snapshot": "node scripts/fetch-reviews-snapshot.mjs",
    "img:meta": "node scripts/inject-image-metadata.mjs"
  },
  "dependencies": {
    "gray-matter": "4.0.3",
    "next": "16.2.6",
    "next-mdx-remote": "6.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^6.12.4"
  },
  "browserslist": [
    "chrome >= 111",
    "safari >= 16",
    "firefox >= 111",
    "edge >= 111"
  ],
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.7.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.1",
    "cheerio": "^1.2.0",
    "exiftool-vendored": "^36.0.0",
    "tailwindcss": "4.3.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "5.9.3"
  }
}
